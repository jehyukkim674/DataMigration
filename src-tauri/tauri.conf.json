{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DataMigration",
  "version": "0.1.9",
  "identifier": "com.gimjaehyeog.datamigration",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DataMigration",
        "width": 1600,
        "height": 1000,
        "minWidth": 720,
        "minHeight": 480,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1NTg0NTM3MTFFRUZDOUMKUldTYy9PNFJOMFZZMWM0dEtNcEhhTW8wV2E5Y2F0NjV5cGp3amtpa3JGWEdhcVZqZUNudlZHUTcK",
      "endpoints": [
        "https://github.com/jehyukkim674/DataMigration/releases/latest/download/latest.json"
      ]
    }
  }
}
